      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Moves"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Movimientos de %@"
          }
        }
      }
    },
    "%@, %lld member(s)" : {
      "comment" : "An accessibility label that describes a type chip in the team analysis view. The label includes the type name and the number of team members affected by that type.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@, %2$lld member(s)"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A numeric value representing a Pokémon's base stat.",
      "isCommentAutoGenerated" : true
    },
    "%lld / 6" : {
      "comment" : "A label showing how many Pokémon are currently on a team. The argument is the number of Pokémon currently on the team.",
      "isCommentAutoGenerated" : true
    },
    "%lld / 6 Pokémon" : {
      "comment" : "A badge displaying the number of Pokémon in the user's team, out of a possible six.",
      "isCommentAutoGenerated" : true
    },
    "♀ %@" : {
      "comment" : "A label showing the percentage of Pokémon that are male. The argument is the percentage of male Pokémon. The argument is the string “%arg%%” or the string “%.1f%%”.",
      "isCommentAutoGenerated" : true
    },
    "♂ %@" : {
      "comment" : "A pair of text labels showing the gender ratio of a Pokémon, formatted as \"♂ 50%\" or \"♀ 50%\". The argument is the string “%arg%%” or the string “%.1f%%”.",
      "isCommentAutoGenerated" : true
    },
