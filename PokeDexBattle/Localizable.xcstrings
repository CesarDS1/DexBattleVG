{
  "sourceLanguage" : "en",
  "strings" : {
    "" : {

    },
    "—" : {
      "comment" : "A placeholder text shown when a type group is empty.",
      "isCommentAutoGenerated" : true
    },
    "#%@" : {
      "comment" : "A subheading displaying a Pokémon's national Pokédex number, zero-padded to three digits. The argument is the string “%03d”.",
      "isCommentAutoGenerated" : true
    },
    "%@ %@" : {
      "comment" : "A badge displaying the type of damage a move deals. The argument is the name of the damage class.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ Evolutions" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Evolutions"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Evoluciones de %@"
          }
        }
      }
    },
    "%@ Forms" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Forms"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
