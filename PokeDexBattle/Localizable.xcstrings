    "about.disclaimer.text" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokémon and all related names, characters, and images are trademarks of Nintendo, Game Freak, and Creatures Inc. This app is not affiliated with, endorsed by, or associated with Nintendo, Game Freak, or The Pokémon Company in any way. All Pokémon assets are used solely for non-commercial, personal purposes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokémon y todos los nombres, personajes e imágenes relacionados son marcas registradas de Nintendo, Game Freak y Creatures Inc. Esta aplicación no está afiliada, respaldada ni asociada con Nintendo, Game Freak ni The Pokémon Company de ninguna forma. Todos los recursos de Pokémon se utilizan únicamente con fines personales y no comerciales."
          }
        }
      }
    },
    "about.pokeapi.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokémon data is provided by PokéAPI (pokeapi.co), a free and open Pokémon RESTful API."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los datos de Pokémon son proporcionados por PokéAPI (pokeapi.co), una API RESTful gratuita y de código abierto."
