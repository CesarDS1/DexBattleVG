# Xcode derived data & build artifacts
DerivedData/
build/
*.xcarchive
*.ipa
*.dSYM.zip
*.dSYM

# Xcode user-specific settings (not shared between developers)
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist

# Swift Package Manager
.build/
.swiftpm/
xcuserdata/

# CocoaPods (not used here, but good to have)
Pods/
*.xcworkspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Instruments
*.trace

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# SwiftData / SQLite local stores (device-specific, regenerated at runtime)
*.sqlite
*.sqlite-wal
*.sqlite-shm
